policyId, policyName, conditionId, conditionName, title, targetName,
       nrqlQuery, nrqlEventType, event, incidentId, incidentLink, runbookUr=
l
FROM NrAiIncident
WHERE entity.guid =3D '{entity_guid}'</pre>
